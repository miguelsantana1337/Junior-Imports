# Sem estas variáveis, a aplicação funciona em modo demonstrativo local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Somente no servidor. Necessária para criar e excluir usuários pelo painel.
SUPABASE_SERVICE_ROLE_KEY=
STOREFRONT_SECURITY_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Administração central e roteamento das lojas SaaS.
PLATFORM_ADMIN_EMAILS="admin@juniorimports.demo"
SAAS_ROOT_DOMAIN=""

# Identidade white-label. O gerador de clientes preenche estes valores.
NEXT_PUBLIC_CLIENT_ID="junior-imports"
NEXT_PUBLIC_STORE_NAME="Junior Imports"
NEXT_PUBLIC_ORDER_PREFIX="JI"
NEXT_PUBLIC_SITE_URL="https://junior-imports.vercel.app"
NEXT_PUBLIC_METADATA_DESCRIPTION="Catálogo privado demonstrativo da Junior Imports. Consulte os produtos e envie seu pedido pelo WhatsApp."
NEXT_PUBLIC_DEFAULT_CHECKOUT_MODE="whatsapp"
NEXT_PUBLIC_STORE_WHATSAPP="5531999999999"
NEXT_PUBLIC_STORE_EMAIL="contato@juniorimports.com.br"
NEXT_PUBLIC_PRIMARY_COLOR="#1677ff"
NEXT_PUBLIC_SECONDARY_COLOR="#69a8ff"
NEXT_PUBLIC_DEFAULT_LOGO_URL="/admin-brand.png"
NEXT_PUBLIC_DEFAULT_FAVICON_URL="/favicon.svg"
NEXT_PUBLIC_SOCIAL_IMAGE_URL="/admin-brand.png"

# Credenciais privadas usadas somente no modo demonstrativo local.
DEMO_ADMIN_NAME="Administrador Demo"
DEMO_ADMIN_EMAIL="admin@juniorimports.demo"
DEMO_ADMIN_PASSWORD="troque-esta-senha-local"
